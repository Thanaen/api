{
  "name": "api",
  "version": "1.0.50",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "module": "src/index.js",
  "scripts": {
    "test": "bun test",
    "test:unit": "bun test test/cache.test.ts test/parsing.test.ts",
    "test:db": "bun test test/cache-repository.test.ts",
    "test:integration": "bun test test/endpoints.test.ts",
    "dev": "bun run --watch src/dev.ts",
    "build": "tsdown",
    "posthog:sourcemaps": "bun scripts/posthog-sourcemaps.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepare": "lefthook install",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun src/db/migrate.ts",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "@elysiajs/openapi": "^1.4.14",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@neondatabase/serverless": "^1.0.2",
    "@sinclair/typebox": ">= 0.34.0 < 1",
    "@vercel/functions": "^3.2.10",
    "drizzle-orm": "^0.45.2",
    "elysia": "latest",
    "node-html-parser": "^7.1.0",
    "posthog-node": "^5.29.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@posthog/cli": "^0.7.4",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.10",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1",
    "tsdown": "^0.21.7"
  }
}
